# Copiar a .env.local y completar con los datos de tu proyecto Supabase
# (Project Settings > API en el dashboard de Supabase)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Solo se usa en el servidor (Server Actions / route handlers), nunca se expone al
# cliente. Necesaria para el alta de empleados (auth.admin.createUser).
SUPABASE_SERVICE_ROLE_KEY=eyJ...
